# -*- tcl -*-
# Tcl package index file, version 1.1
#
package ifneeded @PACKAGE_NAME@ @PACKAGE_VERSION@ [list apply {
	dir {
		load [file join $dir @PKG_LIB_FILE@] [string totitle @PACKAGE_NAME@]
		namespace eval ::resolve [list variable libfile [file join $dir @PKG_LIB_FILE@]]
		if {[file readable [file join $dir library/resolve.tcl]]} {
			# In source tree (autotools in-tree build)
			source [file join $dir library/resolve.tcl]
		} elseif {[file readable [file join $dir resolve_srcdir.txt]]} {
			# Dev build (meson / autotools out-of-tree) - breadcrumb has source root
			set fd [open [file join $dir resolve_srcdir.txt] r]
			set srcdir [read $fd]
			close $fd
			source [file join $srcdir library/resolve.tcl]
			unset fd srcdir
		} else {
			# Installed
			source [file join $dir resolve.tcl]
		}
	}
} $dir]
